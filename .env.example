# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT signing secret
SESSION_SECRET=change-me-to-a-random-string

# Public URL (used for CORS origin and OAuth redirect)
PUBLIC_URL=https://rotinadoatleticano.duckdns.org

# Comma-separated list of allowed Google emails
ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com

# Database path (in Docker, mapped to a volume)
DB_PATH=/app/data/galo-routine.db

# Family ID (used by frontend)
FAMILY_ID=your-family-id
VITE_FAMILY_ID=your-family-id

# Environment
NODE_ENV=production
