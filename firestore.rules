rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is the parent of this family
    function isParent(familyId) {
      return request.auth != null &&
             get(/databases/$(database)/documents/families/$(familyId)).data.parentUid == request.auth.uid;
    }

    // Helper: check if the user is authenticated with the family's UID
    // (both parent and child use the same Firebase Auth UID)
    function isFamilyMember(familyId) {
      return request.auth != null && request.auth.uid == familyId;
    }

    // Family documents
    match /families/{familyId} {
      // Only the parent (owner) can read/write their family doc
      allow read: if isFamilyMember(familyId);
      allow create: if request.auth != null && request.auth.uid == familyId;
      allow update: if isFamilyMember(familyId);
      allow delete: if false; // Families cannot be deleted via client

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      // Periods subcollection
      match /periods/{periodId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);

        // Completions subcollection within periods
        match /completions/{completionId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if false; // Completions cannot be deleted
        }
      }

      // Rewards subcollection
      match /rewards/{rewardId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      // Redemptions subcollection
      match /redemptions/{redemptionId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if false; // Redemptions cannot be deleted
      }

      // Goals subcollection
      match /goals/{goalId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      // Earned badges subcollection
      match /earnedBadges/{badgeId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      // Streak freezes subcollection
      match /streakFreezes/{freezeId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      // Championships subcollection
      match /championships/{championshipId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);

        // Matches subcollection within championships
        match /matches/{matchId} {
          allow read: if isFamilyMember(familyId);
          allow write: if isFamilyMember(familyId);
        }
      }

      // Trophies subcollection
      match /trophies/{trophyId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
